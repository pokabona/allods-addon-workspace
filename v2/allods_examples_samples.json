 ) \n\t\n\twtMainPanel = mainForm:GetChildChecked( \"MainPanel\", false )\nend\n--------------------------------------------------------------------------------\nInit()\n--------------------------------------------------------------------------------\n","keywords":["0","1","10","5","checked","child","common","counter","counter_limit","delta","end","execute","false","form","function","get","global","globals","handler","handlers","if","info","init","initialization","local","log","lua","main","nil","on","panel","params","place","placement","plain","pos","reaction","register","sample","script","set","then","wt","x"]},{"id":"sample_addons/SampleReactionHandler/Text.(WidgetTextView).xdb","kind":"sample_addons_xdb","name":"Text.(WidgetTextView).xdb","relative_path":"SampleReactionHandler/Text.(WidgetTextView).xdb","source_path":"C:\\VK Play\\Аллоды Онлайн\\data\\Mods\\SampleAddons\\SampleReactionHandler\\Text.(WidgetTextView).xdb","size_bytes":352,"text":"<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n<WidgetTextView>\n\t<Placement>\n\t\t<X>\n\t\t\t<Align>WIDGET_ALIGN_BOTH</Align>\n\t\t\t<Pos>20</Pos>\n\t\t\t<HighPos>20</HighPos>\n\t\t</X>\n\t\t<Y>\n\t\t\t<Pos>60</Pos>\n\t\t\t<Size>60</Size>\n\t\t</Y>\n\t</Placement>\n\t<FormatFileRef href=\"Text.txt\" />\n\t<TextStyle>\n\t\t<multiline>true</multiline>\n\t</TextStyle>\n</WidgetTextView>\n","keywords":["0","1","20","60","8","align","encoding","file","format","handler","high","href","multiline","placement","pos","reaction","ref","sample","size","style","text","true","txt","utf","version","view","widget","widget_align_both","x","xdb","xml","y"]},{"id":"sample_addons/SampleReactionHandler/Text.txt","kind":"sample_addons_txt","name":"Text.txt","relative_path":"SampleReactionHandler/Text.txt","source_path":"C:\\VK Play\\Аллоды Онлайн\\data\\Mods\\SampleAddons\\SampleReactionHandler\\Text.txt","size_bytes":190,"text":"��<\u0000b\u0000o\u0000d\u0000y\u0000 \u0000a\u0000l\u0000i\u0000g\u0000n\u0000x\u0000=\u0000\"\u0000c\u0000e\u0000