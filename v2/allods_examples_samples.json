Онлайн\\data\\Mods\\SampleAddons\\SampleZoneAnnounce\\MainForm.(WidgetForm).xdb","size_bytes":780,"text":"<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n<WidgetForm>\n\t<Name>SampleZoneAnnounce</Name>\n\t<Priority>5100</Priority>\n\t<Children>\n\t\t<Item href=\"Announce.(WidgetTextView).xdb\" />\n\t</Children>\n\t<BackLayer href=\"\" />\n\t<FrontLayer href=\"\" />\n\t<Placement>\n\t\t<QuantumScale>false</QuantumScale>\n\t\t<X>\n\t\t\t<Align>WIDGET_ALIGN_BOTH</Align>\n\t\t\t<Sizing>WIDGET_SIZING_DEFAULT</Sizing>\n\t\t\t<Pos>0</Pos>\n\t\t\t<HighPos>0</HighPos>\n\t\t\t<Size>0</Size>\n\t\t</X>\n\t\t<Y>\n\t\t\t<Align>WIDGET_ALIGN_LOW</Align>\n\t\t\t<Sizing>WIDGET_SIZING_DEFAULT</Sizing>\n\t\t\t<Pos>350</Pos>\n\t\t\t<HighPos>0</HighPos>\n\t\t\t<Size>100</Size>\n\t\t</Y>\n\t</Placement>\n\t<Visible>true</Visible>\n\t<Enabled>true</Enabled>\n\t<TransparentInput>true</TransparentInput>\n\t<PickChildrenOnly>false</PickChildrenOnly>\n</WidgetForm>\n","keywords":["0","1","100","350","5100","8","align","announce","back","children","enabled","encoding","false","form","front","high","href","input","item","layer","main","name","only","pick","placement","pos","priority","quantum","sample","scale","size","sizing","text","transparent","true","utf","version","view","visible","widget","widget_align_both","widget_align_low","widget_sizing_default","x","xdb","xml","y","zone"]},{"id":"sample_addons/SampleZoneAnnounce/ScriptSampleZoneAnnounce.lua","kind":"sample_addons_lua","name":"ScriptSampleZoneAnnounce.lua","relative_path":"SampleZoneAnnounce/ScriptSampleZoneAnnounce.lua","source_path":"C:\\VK Play\\Аллоды Онлайн\\data\\Mods\\SampleAddons\\SampleZoneAnnounce\\ScriptSampleZoneAnnounce.lua","size_bytes":2481,"text":"--------------------------------------------------------------------------------\n-- GLOBALS\n--------------------------------------------------------------------------------\n\n-- CONSTANTS\nGlobal( \"MESSAGE_FADE_IN_TIME\", 350 )\nGlobal( \"MESSAGE_FADE_SOLID_TIME\", 4000 )\nGlobal( \"MESSAGE_FADE_OUT_TIME\", 1000 )\n\nGlobal( \"WIDGET_FADE_TRANSPARENT\", 1 )\nGlobal( \"WIDGET_FADE_IN\", 2 )\nGlobal( \"WIDGET_FADE_SOLID\", 3 )\nGlobal( \"WIDGET_FADE_OUT\", 4 )\n\n-- WIDGETS\nGlobal( \"wtMessage\", nil )\n\n-- OTHER\nGlobal( \"fadeStatus\", WIDGET_FADE_TRANSPARENT )\n\n--------------------------------------------------------------------------------\n-- EVENT HANDLERS\n--------------------------------------------------------------------------------\n\n-- EVENT_AVATAR_CLIENT_ZONE_CHANGED\nfunction OnEventAvatarClientZoneChanged( params )\n\tlocal zone = cartographer.GetCurrentZoneInfo()\n\n\tif not common.IsEmptyWString( zone.subZoneName ) then\n\t\twtMessage:SetVal( \"value\", zone.subZoneName )\n\telse\n\t\twtMessage:SetVal( \"value\", zone.zoneName )\n\tend\n\twtMessage:Show( true )\n\n\twtMessage:PlayFadeEffect( 0.0, 1.0, MESSAGE_FADE_IN_TIME, EA_MONOTONOUS_INCREASE )\n\tfadeStatus = WIDGET_FADE_IN\nend\n\n-- EVENT_EFFECT_FINISHED\nfunction OnEventEffectFinished ( params )\n\tif params.wtOwner:IsEqual( wtMessage ) then\n\t\tif fadeStatus == WIDGET_FADE_IN then\n\t\t\twtMessage:PlayFadeEffect( 1.0, 1.0, MESSAGE_FADE_SOLID_TIME, EA_MONOTONOUS_INCREASE )\n\t\t\tfadeStatus = WIDGET_FADE_SOLID\t\t\n\t\telseif fadeStatus == WIDGET_FADE_SOLID then\n\t\t\twtMessage:PlayFadeEffect( 1.0, 0.0, MESSAGE_FADE_OUT_TIME, EA_MONOTONOUS_INCREASE )\n\t\t\tfadeStatus = WIDGET_FADE_OUT\t\t\n\t\telseif fadeStatus == WIDGET_FADE_OUT then\n\t\t\tfadeStatus = WIDGET_FADE_TRANSPARENT\n\t\t\twtMessage:Show( false )\n\t\tend\n\tend\nend\n\n--------------------------------------------------------------------------------\n-- INITIALIZATION\n--------------------------------------------------------------------------------\nfunction Init()\n\tcommon.RegisterEventHandler( OnEventAvatarClientZoneChanged, \"EVENT_AVATAR_CLIENT_ZONE_CHANGED\" )\n\tcommon.RegisterEventHandler( OnEventEffectFinished, \"EVENT_EFFECT_FINISHED\" )\n\t\n\twtMessage = mainForm:GetChildChecked( \"Announce\", false )\n\twtMessage:Show( false )\n\n\tcommon.StateUnloadManagedAddon( \"ZoneAnnounce\" )\nend\n--------------------------------------------------------------------------------\nInit()\n--------------------------------------------------------------------------------\n","keywords":["0","1","1000","2","3","350","4","4000","announce","avatar","cartographer","changed","client","common","constants","current","ea_monotonous_increase","effect","else","elseif","empty","end","equal","event","event_avatar_c","event_avatar_client_zone_changed","event_effect_finished","fade","false","finished","function","get","global","globals","handler","handlers","if","info","init","initialization","is","local","lua","message","message_fade_in_time","message_fade_out_time","message_fade_solid_time","name","nil","not","on","other","owner","params","play","register","sample","script","set","show","status","sub","then","true","val","value","widget_fade_in","widget_fade_out","widget_fade_solid","widget_fade_transparent","widgets","wstring","wt","zone"]},{"id":"sample_addons/SampleLocalization/SampleLocalization.pak","kind":"sample_addons_pak_metadata","name":"SampleLocalization.pak","relative_path":"SampleLocalization/SampleLocalization.pak","source_path":"C:\\VK Play\\Аллоды Онлайн\\data\\Mods\\SampleAddons\\SampleLocalization\\SampleLocalization.pak","size_bytes":2244,"text_included":false,"keywords":["localization","pak","sample"]},{"id":"sample_addons/SampleReactionHandler/MainFrame.(UITexture).bin","kind":"sample_addons_bin_metadata","name":"MainFrame.(UITexture).bin","relative_path":"SampleReactionHandler/MainFrame.(UITexture).bin","source_path":"C:\\VK Play\\Аллоды Онлайн\\data\\Mods\\SampleAddons\\SampleReactionHandler\\MainFrame.(UITexture).bin","size_bytes":1034,"text_included":false,"keywords":["bin","frame","handler","main","reaction","sample","uitexture"]},{"id":"sample_addons/SampleReactionHandler/MainFrame.tga","kind":"sample_addons_tga_metadata","name":"MainFrame.tga