actionHandler\\ScriptSampleReactionHandler.lua","size_bytes":1356,"text":"--------------------------------------------------------------------------------\n-- GLOBALS\n--------------------------------------------------------------------------------\n\nGlobal( \"wtMainPanel\", nil )\nGlobal( \"delta\", 10 )\nGlobal( \"COUNTER_LIMIT\", 5 )\nGlobal( \"counter\", COUNTER_LIMIT )\n\n--------------------------------------------------------------------------------\n-- REACTION HANDLERS\n--------------------------------------------------------------------------------\n\n-- \"execute\"\nfunction OnReactionExecute( params )\n\tLogInfo( \"counter: \", counter )\n\t\n\tcounter = counter - 1\n\tif counter < 0 then\n\t\tcounter = COUNTER_LIMIT\n\t\tdelta = -delta\n\tend\n\t\n\tlocal place = wtMainPanel:GetPlacementPlain()\n\tplace.posX = place.posX + delta\n\twtMainPanel:SetPlacementPlain( place )\nend\n\n--------------------------------------------------------------------------------\n-- INITIALIZATION\n--------------------------------------------------------------------------------\nfunction Init()\n\tLogInfo( \"Reaction handler sample\" )\n\n\tcommon.RegisterReactionHandler( OnReactionExecute, \"execute\" ) \n\t\n\twtMainPanel = mainForm:GetChildChecked( \"MainPanel\", false )\nend\n--------------------------------------------------------------------------------\nInit()\n--------------------------------------------------------------------------------\n","keywords":["0","1","10","5","checked","child","common","counter","counter_limit","delta","end","execute","false","form","function","get","global","globals","handler","handlers","if","info","init","initialization","local","log","lua","main","nil","on","panel","params","place","placement","plain","pos","reaction","register","sample","script","set","then","wt","x"]},{"id":"sample_addons/SampleReactionHandler/Text.(WidgetTextView).xdb","kind":"sample_addons_xdb","name":"Text.(WidgetTextView).xdb","relative_path":"SampleReactionHan